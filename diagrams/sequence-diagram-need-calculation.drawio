                <mxCell id="note1" value="&lt;b&gt;Scoring Algorithm (calculateNeedScore)&lt;/b&gt;&lt;br&gt;vulnerabilityScore = Σ risk × weight&lt;br&gt;accessibilityScore = f(distance, transport, season)&lt;br&gt;capacityScore = f(familySize, income, dependents)&lt;br&gt;composite = 0.5×vuln + 0.3×access + 0.2×(1−capacity)&lt;br&gt;Priority: HIGH &gt;=0.7 | MEDIUM 0.4–0.7 | LOW &lt;0.4" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
                    <mxGeometry x="1230" y="210" width="280" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="msg1" value="1. Open Need Assessment Panel&lt;div&gt;(household list)&lt;/div&gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="180" y="190" as="sourcePoint"/>
                        <mxPoint x="513" y="190" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="msg2" value="2. GET /v1/households?wardNo=X&lt;div&gt;(fetch households for area)&lt;/div&gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="530" y="230" as="sourcePoint"/>
                        <mxPoint x="853" y="230" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="msg3" value="3. find({wardNo, unionNo})" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="870" y="310" as="sourcePoint"/>
                        <mxPoint x="1193" y="310" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="msg4" value="4. Household list" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;dashPattern=8 8;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="1193" y="390" as="sourcePoint"/>
                        <mxPoint x="870" y="390" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="msg5" value="5. Return households to frontend" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;dashPattern=8 8;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="853" y="470" as="sourcePoint"/>
                        <mxPoint x="530" y="470" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="msg6" value="6. Officer selects household and sets risk factors&lt;div&gt;(disability, elderly, etc.)&lt;/div&gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="180" y="530" as="sourcePoint"/>
                        <mxPoint x="513" y="530" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="msg7" value="7. POST /v1/need-assessments&amp;nbsp;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;(body:&lt;/span&gt;&lt;div&gt;householdId, riskFactors, areaAccess, householdCapacity)&lt;/div&gt;" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" parent="1" edge="1">
