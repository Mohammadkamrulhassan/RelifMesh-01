                <mxCell id="note2" value="Server-side: calculateNeedScore()&lt;br&gt;computes vulnerabilityScore,&lt;br&gt;accessibilityScore,&lt;br&gt;capacityScore, compositeScore,&lt;br&gt;and assigns priority" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=8;" parent="1" vertex="1">
