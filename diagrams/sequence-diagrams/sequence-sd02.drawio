        <mxCell id="lifeline-db" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;noLabel=1;rotation=0;" vertex="1" parent="1">
          <mxGeometry x="1110" y="60" width="10" height="3100" as="geometry" />
        </mxCell>

        <!-- Lifeline: Official -->
        <mxCell id="ll-official" value="UP Official&#10;/ Upazila Officer" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1320" y="20" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lifeline-official" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;noLabel=1;rotation=0;" vertex="1" parent="1">
          <mxGeometry x="1400" y="60" width="10" height="3100" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 1: CITIZEN SUBMITS RELIEF REQUEST ========== -->

        <mxCell id="label-sec1" value="&lt;b&gt;&lt;i&gt;--- Citizen Submits Relief Request ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="550" y="100" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 1. Citizen -> FE -->
        <mxCell id="arrow1" value="1. Fill relief request form&#10;(items, priority, location)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-citizen" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2. FE -> BE -->
        <mxCell id="arrow2" value="2. POST /v1/relief-requests&#10;(JWT in Authorization header)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BE activation: Verify JWT -->
        <mxCell id="act-auth" value="Verify JWT&#10;Extract citizenId" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="200" width="110" height="40" as="geometry" />
        </mxCell>

        <!-- 3. BE -> DB -->
        <mxCell id="arrow3" value="3. db.relief_requests.insertOne({citizenId, items, priority, location, status:'PENDING'})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. DB -> BE -->
        <mxCell id="arrow4" value="4. Created document" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-db" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 5. BE -> FE -->
        <mxCell id="arrow5" value="5. 201 Created + reliefRequest object" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6. FE -> Citizen -->
        <mxCell id="arrow6" value="6. Show success toast + redirect to My Requests" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-citizen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 2: OFFICIAL VIEWS PENDING REQUESTS ========== -->

        <mxCell id="label-sec2" value="&lt;b&gt;&lt;i&gt;--- Official Reviews Pending Requests ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="550" y="440" width="350" height="30" as="geometry" />
        </mxCell>

        <!-- 7. Official -> FE -->
        <mxCell id="arrow7" value="7. Navigate to Relief Requests Admin page" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-official" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8. FE -> BE -->
        <mxCell id="arrow8" value="8. GET /v1/relief-requests/admin?status=PENDING" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9. BE -> DB -->
        <mxCell id="arrow9" value="9. db.relief_requests.find({status:'PENDING'}).populate('citizenId')" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 10. DB -> BE -->
        <mxCell id="arrow10" value="10. Cursor → array of request documents" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-db" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 11. BE -> FE -->
        <mxCell id="arrow11" value="11. 200 OK + reliefRequests[]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FE activation: Render -->
        <mxCell id="act-show" value="Render table&#10;of PENDING requests" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="445" y="650" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- 12. FE -> Official -->
        <mxCell id="arrow12" value="12. Display requests table with Approve / Reject buttons" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-official">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 3: OFFICIAL MAKES DECISION ========== -->

        <mxCell id="label-sec3" value="&lt;b&gt;&lt;i&gt;--- Official Approves / Rejects Request ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="550" y="790" width="350" height="30" as="geometry" />
        </mxCell>

        <!-- 13. Official -> FE -->
        <mxCell id="arrow13" value="13. Click Approve or Reject, add reviewNotes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-official" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 14. FE -> BE -->
        <mxCell id="arrow14" value="14. PUT /v1/relief-requests/admin/:id/review&#10;{status: 'APPROVED'|'REJECTED', reviewNotes}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BE activation: process review -->
        <mxCell id="act-review" value="Validate status enum&#10;Set reviewedBy, reviewedAt&#10;Save reviewNotes" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="765" y="920" width="140" height="50" as="geometry" />
        </mxCell>

        <!-- 15. BE -> DB -->
        <mxCell id="arrow15" value="15. db.relief_requests.updateOne({_id},&#10;{status, reviewedBy, reviewedAt, reviewNotes})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 16. DB -> BE -->
        <mxCell id="arrow16" value="16. {nModified: 1}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-db" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 17. BE -> FE -->
        <mxCell id="arrow17" value="17. 200 OK + updated reliefRequest" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 18. FE -> Official -->
        <mxCell id="arrow18" value="18. Show success + refresh filtered list" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-official">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 4: CITIZEN SEES UPDATED STATUS ========== -->

        <mxCell id="label-sec4" value="&lt;b&gt;&lt;i&gt;--- Citizen Checks Updated Status ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="550" y="1210" width="320" height="30" as="geometry" />
        </mxCell>

        <!-- 19. Citizen -> FE -->
        <mxCell id="arrow19" value="19. Navigate to My Relief Requests" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-citizen" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 20. FE -> BE -->
        <mxCell id="arrow20" value="20. GET /v1/relief-requests/mine" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 21. BE -> DB -->
        <mxCell id="arrow21" value="21. db.relief_requests.find({citizenId}).sort({createdAt:-1})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 22. DB -> BE -->
        <mxCell id="arrow22" value="22. Cursor → request documents with status" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-db" target="lifeline-be">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 23. BE -> FE -->
        <mxCell id="arrow23" value="23. 200 OK + reliefRequests[]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-be" target="lifeline-fe">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 24. FE -> Citizen -->
        <mxCell id="arrow24" value="24. Render My Requests list with status badges&#10;(PENDING / APPROVED / REJECTED)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-fe" target="lifeline-citizen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

