        <!-- Lifeline: Backend -->
        <mxCell id="ll-be" value="Backend (Express)" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="720" y="20" width="160" height="40" as="geometry" />
