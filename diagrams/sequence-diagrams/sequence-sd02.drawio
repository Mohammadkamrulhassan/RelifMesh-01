        <mxCell id="lifeline-be" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;noLabel=1;rotation=0;" vertex="1" parent="1">
          <mxGeometry x="800" y="60" width="10" height="3100" as="geometry" />
        </mxCell>

        <!-- Lifeline: MongoDB -->
        <mxCell id="ll-db" value="MongoDB" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1040" y="20" width="140" height="40" as="geometry" />
