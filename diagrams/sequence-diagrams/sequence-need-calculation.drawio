        <mxCell id="arrow13" value="13. Show updated effectiveQty&#10;with override reason" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-dashboard" target="lifeline-officer">
