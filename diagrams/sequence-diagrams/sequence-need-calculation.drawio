        </mxCell>

        <!-- ========== SECTION 1: NEED CALCULATION FLOW ========== -->

        <mxCell id="label-sec1" value="&lt;b&gt;&lt;i&gt;--- Calculate Ward Needs ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="600" y="110" width="250" height="30" as="geometry" />
        </mxCell>

        <!-- 1. Officer -> Dashboard -->
        <mxCell id="arrow1" value="1. Selects ward (geographicArea) &amp; coverage days" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-officer" target="lifeline-dashboard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2. Dashboard -> Controller -->
        <mxCell id="arrow2" value="2. POST /v1/need/calculate&#10;{areaId, days}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-dashboard" target="lifeline-controller">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Controller activation -->
        <mxCell id="act-coord" value="Coordinate&#10;need calculation" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="220" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- 3. Controller -> GeographicArea -->
        <mxCell id="arrow3" value="3. GeographicArea.findById(areaId)&#10;-> verify level === 'WARD'" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-geo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. Controller -> Household -->
        <mxCell id="arrow4" value="4. Household.aggregate([&#10;  {$match: {jurisdictionId}},&#10;  {$group: {_id: '$demographics', count: {$sum: 1}}}])" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-household">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 5. Controller -> ItemCategory -->
        <mxCell id="arrow5" value="5. ItemCategory.find({isActive:true})&#10;-> get perPersonRates[]" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-itemcat">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6. Controller -> NeedAssessment -->
        <mxCell id="arrow6" value="6. loop: effectiveQty = pop * rate * days&#10;NeedAssessment.findOneAndUpdate(&#10;  {areaId, itemId}, {effectiveQty}, {upsert:true})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-assessment">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7. Controller -> Dashboard (return) -->
        <mxCell id="arrow7" value="7. 200 OK + assessments[] with effectiveQty" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-dashboard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8. Dashboard -> Officer -->
        <mxCell id="arrow8" value="8. Display ward table with item breakdown&#10;(food, water, shelter per demographic)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-dashboard" target="lifeline-officer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 2: OVERRIDE PATH ========== -->

        <mxCell id="label-sec2" value="&lt;b&gt;&lt;i&gt;--- Officer Overrides Calculated Qty ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="600" y="750" width="320" height="30" as="geometry" />
        </mxCell>

        <!-- 9. Officer -> Dashboard -->
        <mxCell id="arrow9" value="9. Clicks Override, enters new qty + reason" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-officer" target="lifeline-dashboard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 10. Dashboard -> Controller -->
        <mxCell id="arrow10" value="10. POST /v1/need/:id/override&#10;{overrideQty, reason}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-dashboard" target="lifeline-controller">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Controller activation: override -->
        <mxCell id="act-override" value="Process override&#10;Set overriddenBy" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="690" y="890" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- 11. Controller -> NeedAssessment -->
        <mxCell id="arrow11" value="11. NeedAssessment.findByIdAndUpdate({&#10;  overrideQty, overriddenBy: userId,&#10;  overrideReason, overriddenAt: now})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-assessment">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 12. Controller -> Dashboard (return) -->
        <mxCell id="arrow12" value="12. 200 OK + updated assessment" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-controller" target="lifeline-dashboard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

