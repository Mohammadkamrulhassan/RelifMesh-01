        <!-- ========== SECTION 1: PLEDGE CREATION ========== -->

        <mxCell id="label-sec1" value="&lt;b&gt;&lt;i&gt;--- NGO Worker Creates Pledge ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 1. NGO -> PledgeForm -->
        <mxCell id="arrow1" value="1. Fills source, area, item, qty, submits" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-ngo" target="lifeline-pledgeform">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2. PledgeForm -> PledgeController -->
        <mxCell id="arrow2" value="2. POST /v1/pledges&#10;{source, areaId, itemId, totalQty}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-pledgeform" target="lifeline-pledgectrl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- PledgeController activation -->
        <mxCell id="act-create" value="Create&#10;pledge" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1610" y="220" width="100" height="40" as="geometry" />
        </mxCell>

        <!-- 3. PledgeController -> ReliefPledge -->
        <mxCell id="arrow3" value="3. ReliefPledge.create({source, areaId,&#10;itemId, totalQty, status:'PENDING',&#10;distributedQty:0})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-pledgectrl" target="lifeline-pledge">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. PledgeController -> PledgeForm (return) -->
        <mxCell id="arrow4" value="4. 201 Created + pledge object" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-pledgectrl" target="lifeline-pledgeform">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 5. PledgeForm -> NGO -->
        <mxCell id="arrow5" value="5. Confirmation: pledge created (PENDING)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-pledgeform" target="lifeline-ngo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 2: FULFILLMENT VIA DISTRIBUTION ========== -->

        <mxCell id="label-sec2" value="&lt;b&gt;&lt;i&gt;--- Later: Officer Fulfills Pledge via Distribution ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="700" y="420" width="400" height="30" as="geometry" />
        </mxCell>

        <!-- 6. Officer -> DistributionForm -->
        <mxCell id="arrow6" value="6. Creates distribution, selects&#10;pledgeId from dropdown" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-officer" target="lifeline-distform">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7. DistributionForm -> DistributionController -->
        <mxCell id="arrow7" value="7. POST /v1/distributions&#10;{householdId, itemId, qty, pledgeId}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-distform" target="lifeline-distctrl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- DistributionController activation -->
        <mxCell id="act-dist" value="Process&#10;distribution" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1910" y="560" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- 8. DistributionController -> DistributionLog -->
        <mxCell id="arrow8" value="8. pre-save hook fires on DistributionLog:&#10;if (pledgeId) increment ReliefPledge.distributedQty" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-distctrl" target="lifeline-distlog">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9. DistributionLog -> ReliefPledge -->
        <mxCell id="arrow9" value="9. ReliefPledge.findByIdAndUpdate({&#10;$inc: {distributedQty: qty}})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-distlog" target="lifeline-pledge">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ReliefPledge activation: auto-status -->
        <mxCell id="act-status" value="Pre-save hook:&#10;if remaining === 0:&#10;  status = COMPLETED&#10;else:&#10;  status = IN_FULFILLMENT" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="2210" y="690" width="170" height="70" as="geometry" />
        </mxCell>

        <!-- 10. ReliefPledge -> DistributionLog (return) -->
