          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 12. DistributionForm -> Officer -->
        <mxCell id="arrow12" value="12. Distribution logged, pledge auto-updated" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-distform" target="lifeline-officer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

