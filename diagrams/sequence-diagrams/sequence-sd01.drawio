            <mxPoint x="0.5" y="30" relative="1" as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- BE -> DB -->
        <mxCell id="arrow3" value="3. db.users.insertOne()" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="lifeline-backend" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

