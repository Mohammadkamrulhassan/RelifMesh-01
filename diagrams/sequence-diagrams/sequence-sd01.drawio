        <!-- === SELF-REGISTRATION FLOW === -->

        <!-- Request form -->
        <mxCell id="arrow1" value="1. Fill register form" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="lifeline-citizen" target="lifeline-frontend">
          <mxGeometry x="0.5" y="20" relative="1" as="geometry">
            <mxPoint as="offset" />
          </mxGeometry>
        </mxCell>

        <!-- FE -> BE -->
        <mxCell id="arrow2" value="2. POST /auth/register/citizen" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;" edge="1" parent="1" source="lifeline-frontend" target="lifeline-backend">
