        <mxCell id="msg11" value="11. Login success, redirect to dashboard" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;dashPattern=8 8;fontSize=12;fontColor=#333333;" edge="1" parent="1">
