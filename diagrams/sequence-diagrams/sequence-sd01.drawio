        <mxCell id="lifeline-backend" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;noLabel=1;rotation=0;" vertex="1" parent="1">
          <mxGeometry x="820" y="60" width="10" height="1500" as="geometry" />
        </mxCell>

        <!-- Lifeline: MongoDB -->
        <mxCell id="ll-db" value="MongoDB" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1040" y="20" width="160" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lifeline-db" value="" style="line;strokeWidth=2;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;noLabel=1;rotation=0;" vertex="1" parent="1">
          <mxGeometry x="1120" y="60" width="10" height="1500" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 1: SELF-REGISTRATION FLOW ========== -->

        <mxCell id="label-sec1" value="&lt;b&gt;&lt;i&gt;--- New Citizen Self-Registration ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="110" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- 1. Citizen -> FE -->
        <mxCell id="arrow1" value="1. Fill register form (name, email, phone, password)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-citizen" target="lifeline-frontend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 2. FE -> BE -->
        <mxCell id="arrow2" value="2. POST /v1/auth/register/citizen&#10;{name, email, phone, password}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-frontend" target="lifeline-backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 3. BE -> DB -->
        <mxCell id="arrow3" value="3. db.users.insertOne({name, email, phone,&#10;password: bcrypt.hash, role:'CITIZEN'})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-backend" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. DB -> BE -->
        <mxCell id="arrow4" value="4. User document created" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-db" target="lifeline-backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BE activation: Generate JWT -->
        <mxCell id="act-jwt" value="Generate JWT&#10;{id, role, exp}" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="790" y="310" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- 5. BE -> FE -->
        <mxCell id="arrow5" value="5. 201 Created + {token, user: {_id, name, email, role}}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-backend" target="lifeline-frontend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FE activation: Store token -->
        <mxCell id="act-store-reg" value="localStorage.setItem('token', jwt)" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="465" y="390" width="180" height="30" as="geometry" />
        </mxCell>

        <!-- 6. FE -> Citizen -->
        <mxCell id="arrow6" value="6. Redirect to /relief-requests" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-frontend" target="lifeline-citizen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== SECTION 2: EXISTING USER LOGIN ========== -->

        <mxCell id="label-sec2" value="&lt;b&gt;&lt;i&gt;--- Existing User Login ---&lt;/i&gt;&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="450" y="510" width="250" height="30" as="geometry" />
        </mxCell>

        <!-- 7. Citizen -> FE -->
        <mxCell id="arrow7" value="7. Enter email + password on login page" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-citizen" target="lifeline-frontend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8. FE -> BE -->
        <mxCell id="arrow8" value="8. POST /v1/auth/login&#10;{email, password}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-frontend" target="lifeline-backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9. BE -> DB -->
        <mxCell id="arrow9" value="9. db.users.findOne({email})" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-backend" target="lifeline-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 10. DB -> BE -->
        <mxCell id="arrow10" value="10. User document (or null)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;dashed=1;fontSize=12;" edge="1" parent="1" source="lifeline-db" target="lifeline-backend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- BE activation: Verify password -->
        <mxCell id="act-verify" value="bcrypt.compareSync&#10;(password, hash)&#10;Generate JWT" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="785" y="700" width="130" height="50" as="geometry" />
        </mxCell>

        <!-- 11. BE -> FE -->
        <mxCell id="arrow11" value="11. 200 OK + {token, user: {_id, name, role, ...}}" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-backend" target="lifeline-frontend">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- FE activation: Store JWT -->
        <mxCell id="act-store" value="localStorage.setItem('token', jwt)&#10;Set auth headers for future requests" style="shape=rect;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;rounded=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="445" y="790" width="210" height="40" as="geometry" />
        </mxCell>

        <!-- 12. FE -> Citizen -->
        <mxCell id="arrow12" value="12. Redirect to /dashboard" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=blockThin;endFill=1;fontSize=12;" edge="1" parent="1" source="lifeline-frontend" target="lifeline-citizen">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

