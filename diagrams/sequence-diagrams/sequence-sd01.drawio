          <mxGeometry x="1302" y="360" width="18" height="320" as="geometry"/>
        </mxCell>

        <!-- ==================== MESSAGES ==================== -->

        <!-- 1. Citizen → Frontend: Login Request -->
        <mxCell id="msg1" value="1. Login Request (email, password)" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="260" y="200" as="sourcePoint"/>
            <mxPoint x="603" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 2. Frontend → Backend: POST /api/auth/login -->
        <mxCell id="msg2" value="2. POST /api/auth/login" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="620" y="280" as="sourcePoint"/>
            <mxPoint x="953" y="280" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 3. Backend → Database: Query user by email -->
        <mxCell id="msg3" value="3. Query user by email" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="970" y="360" as="sourcePoint"/>
            <mxPoint x="1303" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 4. Database → Backend: User record (return) -->
        <mxCell id="msg4" value="4. User record" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;dashPattern=8 8;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1303" y="440" as="sourcePoint"/>
            <mxPoint x="970" y="440" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 5. Backend → Backend: Verify password hash (self-call) -->
        <mxCell id="msg5" value="5. Verify password hash" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;labelPosition=right;verticalLabelPosition=middle;align=left;verticalAlign=middle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="970" y="520" as="sourcePoint"/>
            <mxPoint x="970" y="555" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1080" y="520"/>
              <mxPoint x="1080" y="555"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 6. Backend → Database: Update lastLogin timestamp -->
        <mxCell id="msg6" value="6. Update lastLogin timestamp" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="970" y="600" as="sourcePoint"/>
            <mxPoint x="1303" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 7. Database → Backend: Update confirmed (return) -->
        <mxCell id="msg7" value="7. Update confirmed" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;dashPattern=8 8;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1303" y="680" as="sourcePoint"/>
            <mxPoint x="970" y="680" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 8. Backend → Backend: Generate JWT token (self-call) -->
        <mxCell id="msg8" value="8. Generate JWT token" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;labelPosition=right;verticalLabelPosition=middle;align=left;verticalAlign=middle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="970" y="760" as="sourcePoint"/>
            <mxPoint x="970" y="795" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="1080" y="760"/>
              <mxPoint x="1080" y="795"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 9. Backend → Frontend: 200 OK {token, user} (return) -->
        <mxCell id="msg9" value="9. 200 OK {token, user}" style="html=1;verticalAlign=bottom;endArrow=open;endFill=0;dashed=1;dashPattern=8 8;fontSize=12;fontColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="953" y="840" as="sourcePoint"/>
            <mxPoint x="620" y="840" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <!-- 10. Frontend → Frontend: Store token in localStorage (self-call) -->
        <mxCell id="msg10" value="10. Store token in localStorage" style="html=1;verticalAlign=bottom;endArrow=block;endFill=1;fontSize=12;fontColor=#333333;labelPosition=right;verticalLabelPosition=middle;align=left;verticalAlign=middle;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
