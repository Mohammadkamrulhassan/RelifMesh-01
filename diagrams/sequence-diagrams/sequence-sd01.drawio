        <mxCell id="box_citizen" value="&lt;b&gt;Citizen&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;verticalLabelPosition=bottom;fontSize=13;fontStyle=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
