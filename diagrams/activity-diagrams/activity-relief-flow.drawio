          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- sys-pledge-save -> sys-pledge-status (within system) -->
        <mxCell id="f-sys-pledge-auto" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="sys-pledge-save" target="sys-pledge-status">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- sys-pledge-status -> ngo-track (cross-lane dashed: status update) -->
        <mxCell id="f-auto-track" value="Pledge status update" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="sys-pledge-status" target="ngo-track">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- off-override -> sys-pledge-save (cross-lane: Officer also creates pledges) -->
        <mxCell id="f-override-pledge" value="Officer also&#10;creates pledges" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="off-override" target="sys-pledge-save">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ngo-login -> sys-jwt (cross-lane dashed: auth login) -->
        <mxCell id="f-ngo-login-sys" value="POST /auth/login" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="ngo-login" target="sys-jwt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ngo-track -> ngo-end (within NGO lane) -->
        <mxCell id="f-track-end" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="ngo-track" target="ngo-end">
