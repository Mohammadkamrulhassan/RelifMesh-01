          <mxGeometry x="390" y="490" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Save Pledge -->
        <mxCell id="sys-pledge-save" value="Save Pledge from&#10;NGO/Donor" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="390" y="530" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Auto-Update Pledge Status -->
        <mxCell id="sys-pledge-status" value="Auto-Update&#10;Pledge Status" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="390" y="610" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- === OFFICIAL ACTIVITIES === -->

