        <mxCell id="act-register" value="Self-Register&#10;(name, email, phone, password)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
