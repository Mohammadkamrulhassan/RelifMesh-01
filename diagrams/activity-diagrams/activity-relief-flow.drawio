          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- off-override -> sys-notify (cross-lane dashed: override triggers re-notify) -->
        <mxCell id="f-override-notify" value="POST /need/:id/override" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="1" source="off-override" target="sys-notify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ngo-pledge -> sys-pledge-save (cross-lane: Create Relief Pledge -> Save Pledge) -->
