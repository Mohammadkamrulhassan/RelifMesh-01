{
  "name": "relifmesh-backend",
  "version": "1.0.0",
  "description": "RelifMesh — Disaster Relief Coordination API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "seed": "node db/seeds/seed.js",
    "db:status": "node db/status.js",
    "db:update": "node db/update.js",
    "db:reset": "node db/update.js && node db/seeds/seed.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "json2csv": "^6.0.0-alpha.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
