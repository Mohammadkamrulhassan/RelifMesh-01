# ─── Database ─────────────────────────────────────────────────
# MongoDB Atlas connection
MONGODB_USERNAME="your_db_username"
MONGODB_PASSWORD="your_db_password"
MONGODB_URI=mongodb+srv://your_db_username:your_db_password@cluster0.vrydts3.mongodb.net/relifmesh?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-this-to-a-random-32-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-32-char-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# SMS (for OTP — use 'mock' for development)
SMS_PROVIDER=mock
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Storage — Cloudinary for photo uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payment — Sandbox credentials (bKash / Nagad / Rocket)
BKASH_MERCHANT_NUMBER=
NAGAD_MERCHANT_NUMBER=
ROCKET_MERCHANT_NUMBER=

# Redis — for OTP cache, rate limiting, Socket.io adapter
# Local: redis://localhost:6379
# Upstash (free): <REST_URL> from Upstash dashboard
REDIS_URL=redis://localhost:6379

# App
PORT=5000
NODE_ENV=development

# CORS — Frontend URL for allowed origin
FRONTEND_URL=http://localhost:5173
